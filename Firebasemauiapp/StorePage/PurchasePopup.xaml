<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Firebasemauiapp.StorePage.PurchasePopup"
             x:Name="PopupRoot">

    <!-- Semi-transparent overlay -->
    <Grid BackgroundColor="#80000000">

        <!-- Popup card -->
        <Border BackgroundColor="White"
                WidthRequest="320"
                Padding="28,24"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.3"
                        Radius="24"
                        Offset="0,8"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="20">
                <!-- Icon and Title -->
                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center">
                    <!-- Icon changes based on popup type -->
                    <Border x:Name="IconBorder"
                            WidthRequest="64"
                            HeightRequest="64"
                            BackgroundColor="#50A65D"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <Ellipse/>
                        </Border.StrokeShape>
                        <Label x:Name="IconLabel"
                               Text="🛒"
                               FontSize="32"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label x:Name="TitleLabel"
                           Text="Confirm Purchase"
                           FontFamily="AppFont"
                           FontSize="22"
                           TextColor="#2C5E5E"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Message -->
                <Label x:Name="MessageLabel"
                       Text="Message goes here"
                       TextColor="#555555"
                       FontFamily="contextfont"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       LineHeight="1.4"
                       Margin="0,0,0,4"/>

                <!-- Buttons Grid (2 buttons for confirmation, 1 for alerts) -->
                <Grid x:Name="ButtonsGrid"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,8,0,0">
                    <!-- Cancel/No button -->
                    <Button x:Name="CancelButton"
                            Grid.Column="0"
                            Text="Cancel"
                            BackgroundColor="White"
                            TextColor="#50A65D"
                            BorderColor="#50A65D"
                            BorderWidth="2"
                            FontFamily="contextfont"
                            FontSize="14"
                            CornerRadius="12"
                            HeightRequest="48"
                            Clicked="OnCancelClicked">
                        <Button.Shadow>
                            <Shadow Brush="Black"
                                    Opacity="0.15"
                                    Radius="8"
                                    Offset="0,2"/>
                        </Button.Shadow>
                    </Button>

                    <!-- Confirm/OK button -->
                    <Button x:Name="ConfirmButton"
                            Grid.Column="1"
                            Text="Purchase"
                            BackgroundColor="#50A65D"
                            TextColor="White"
                            FontFamily="contextfont"
                            FontSize="14"
                            CornerRadius="12"
                            HeightRequest="48"
                            Clicked="OnConfirmClicked">
                        <Button.Shadow>
                            <Shadow Brush="Black"
                                    Opacity="0.15"
                                    Radius="8"
                                    Offset="0,2"/>
                        </Button.Shadow>
                    </Button>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
