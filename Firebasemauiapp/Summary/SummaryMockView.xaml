<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Firebasemauiapp.Mainpages.SummaryMockView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    Title="Summary Mock"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#FEAA3A">

    <!-- Key Themes page with sticky note cards -->
    <Grid RowDefinitions="Auto,*,Auto">

        <Image Source="summarybg.png"
               Grid.RowSpan="3"
               Aspect="AspectFill"
               InputTransparent="True"/>

        <!-- Header: Key Themes -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="-6"
                             Margin="40,30,0,10"
                             VerticalOptions="Start">
            <Label Text="Key"
                   FontFamily="AppFont"
                   FontSize="44"
                   FontAttributes="Bold"
                   TextColor="White"/>
            <Label Text="Themes"
                   FontFamily="AppFont"
                   FontSize="44"
                   FontAttributes="Bold"
                   TextColor="White"/>
        </VerticalStackLayout>

        <!-- Sticky note cards layout -->
        <AbsoluteLayout Grid.Row="1"
                        Padding="10">



            <!-- Card 2: Blue note with red tape (top-right) -->
            <Grid AbsoluteLayout.LayoutBounds="200,-10,240,240"
                  Rotation="3">
                <Image Source="postit1.png"
                       Aspect="AspectFill"/>
                <Label Text="Family"
                       FontFamily="AppFont"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#2C5E5E"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TranslationY="10"/>
            </Grid>
            <!-- Card 1: Purple note with 3 holes (left side) -->
            <Grid AbsoluteLayout.LayoutBounds="-5,80,240,240"
                  Rotation="3">
                <Image Source="postit2.png"
                       Aspect="AspectFill"/>
                <Label Text="Dinner"
                       FontFamily="AppFont"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#2C5E5E"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Grid>
            <!-- Card 3: Pink note with dots and orange tape (middle-right) -->
            <Grid AbsoluteLayout.LayoutBounds="220,235,220,220"
                  Rotation="2">
                <Image Source="postit3.png"
                       Aspect="AspectFill"/>
                <Label Text="Gift"
                       FontFamily="AppFont"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#2C5E5E"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Grid>

            <!-- Card 4: Green note with curved corner (bottom-left) -->
            <Grid AbsoluteLayout.LayoutBounds="-5,320,240,240"
                  Rotation="-4">
                <Image Source="postit4.png"
                       Aspect="AspectFill"/>
                <Label Text="Surprise"
                       FontFamily="AppFont"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#2C5E5E"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Grid>

            <!-- Card 5: Light pink note with blue tape (bottom-right) -->
            <Grid AbsoluteLayout.LayoutBounds="180,440,240,240"
                  Rotation="-2">
                <Image Source="postit5.png"
                       Aspect="AspectFill"/>
                <Label Text="Long Distance"
                       FontFamily="AppFont"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#2C5E5E"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       LineBreakMode="WordWrap"
                       HorizontalTextAlignment="Center"
                       MaxLines="2"/>
            </Grid>
        </AbsoluteLayout>

        <!-- Bottom controls -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*,Auto"
              Padding="20"
              Margin="0,0,0,12">

            <!-- Page indicator dots (left) -->
            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="8"
                                   VerticalOptions="Center">
                <Ellipse WidthRequest="10"
                         HeightRequest="10"
                         Fill="White"/>
                <Ellipse WidthRequest="10"
                         HeightRequest="10"
                         Fill="#80FFFFFF"/>
                <Ellipse WidthRequest="10"
                         HeightRequest="10"
                         Fill="#80FFFFFF"/>
            </HorizontalStackLayout>

            <!-- Next button (right) -->
            <Button Grid.Column="2"
                    Text="Next"
                    BackgroundColor="#8FB78F"
                    TextColor="White"
                    FontFamily="AppFont"
                    FontSize="18"
                    CornerRadius="24"
                    WidthRequest="120"
                    HeightRequest="48"
                    Command="{Binding NextPageCommand}">
                <Button.Shadow>
                    <Shadow Brush="#40000000"
                            Radius="16"
                            Offset="0,4"
                            Opacity="0.35"/>
                </Button.Shadow>
            </Button>
        </Grid>
    </Grid>


</ContentPage>
