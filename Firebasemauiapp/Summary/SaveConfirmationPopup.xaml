<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Firebasemauiapp.Summary.SaveConfirmationPopup"
             x:Name="PopupRoot">

    <!-- Semi-transparent overlay -->
    <Grid BackgroundColor="#80000000">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnOverlayTapped"/>
        </Grid.GestureRecognizers>

        <!-- Popup card -->
        <Border BackgroundColor="White"
                WidthRequest="300"
                Padding="32,24"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.3"
                        Radius="24"
                        Offset="0,8"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="20">
                <!-- Title -->
                <Label Text="Before You Go..."
                       FontFamily="AppFont"
                       FontSize="24"
                       TextColor="#2C5E5E"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="#E0E0E0"
                         Margin="0,0,0,4"/>

                <!-- Message -->
                <Label TextColor="#555555"
                       FontFamily="contextfont"
                       FontSize="14"
                       HorizontalTextAlignment="Start"
                       LineHeight="1.4">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Do you want to keep this entry, or would&#10;you like to let it go?&#10;&#10;"/>
                            <Span Text="Keeping or letting go,&#10;both are acts of self-love.&#10;&#10;"/>
                            <Span Text="Trust your heart—it knows what you&#10;need."/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <!-- Buttons -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,8,0,0">
                    <!-- Let it go button -->
                    <Button Grid.Column="0"
                            Text="Let it go"
                            BackgroundColor="#50A65D"
                            TextColor="White"
                            FontFamily="contextfont"
                            FontSize="14"
                            CornerRadius="12"
                            HeightRequest="48"
                            Clicked="OnLetItGoClicked">
                        <Button.Shadow>
                            <Shadow Brush="Black"
                                    Opacity="0.15"
                                    Radius="8"
                                    Offset="0,2"/>
                        </Button.Shadow>
                    </Button>

                    <!-- Keep it button -->
                    <Button Grid.Column="1"
                            Text="Keep it"
                            BackgroundColor="White"
                            TextColor="#50A65D"
                            BorderColor="#50A65D"
                            BorderWidth="2"
                            FontFamily="contextfont"
                            FontSize="14"
                            CornerRadius="12"
                            HeightRequest="48"
                            Clicked="OnKeepItClicked">
                        <Button.Shadow>
                            <Shadow Brush="Black"
                                    Opacity="0.15"
                                    Radius="8"
                                    Offset="0,2"/>
                        </Button.Shadow>
                    </Button>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
